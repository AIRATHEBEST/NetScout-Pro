# ─── Security (CHANGE THESE) ─────────────────────────────────
AGENT_TOKEN=my-super-secret-agent-token-change-this
SECRET_KEY=my-super-secret-jwt-key-change-this

# ─── Supabase (NetGuru Pro project) ──────────────────────────
# Get your DB password from: Supabase Dashboard > Settings > Database
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-DB-PASSWORD]@db.jqteahtqwffjenserypk.supabase.co:5432/postgres
SUPABASE_URL=https://jqteahtqwffjenserypk.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Redis (use Upstash free tier for cloud) ──────────────────
# https://upstash.com → create Redis DB → copy URL
REDIS_URL=redis://localhost:6379/0

# ─── Agent Settings ───────────────────────────────────────────
AGENT_ID=agent-001
BACKEND_WS_URL=ws://localhost:8000/ws/agent
BACKEND_API_URL=http://localhost:8000

# ─── Scan Behaviour ───────────────────────────────────────────
SCAN_INTERVAL_SECONDS=60
ENABLE_PORT_SCAN=true
ENABLE_OS_DETECTION=true
ENABLE_MDNS=true

# ─── Network Override (optional — auto-detected if blank) ─────
# NETWORK_INTERFACE=eth0
# NETWORK_CIDR=192.168.1.0/24

# ─── Debug ────────────────────────────────────────────────────
DEBUG=false
